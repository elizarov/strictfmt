# Mirrors $(userver)/.cpp-format style for userver golden fixtures.
# Keep style fields in sync with the formatter config used by the adjacent userver checkout.
# Userver-specific MacroCategories entries below are parser grammar inputs.
# No IncludeCategories entry: mirrors userver .clang-format IncludeBlocks: Preserve behavior.
---
ColumnLimit: 120
IndentWidth: 4
TabWidth: 4

MainIncludeChar: Quote
IncludeIsMainRegex: '(Test)?$'

MacroCategories:
  StatementLikeParameters:
    - X
  RawMacroFunctionDefinitions:
    - IMPL_UTEST_ASSERT_NO_THROW
    - IMPL_UTEST_ASSERT_THROW
    - IMPL_UTEST_ANY_BEGIN
    - IMPL_UTEST_ANY_END
    - IMPL_UTEST_HIDE_USER_FIXTURE_BY_TEST_LAUNCHER
    - IMPL_UTEST_HIDE_USER_FIXTURE_BY_TEST_LAUNCHER_TYPED
    - IMPL_UTEST_MAKE_USER_FIXTURE_ALIAS_TYPED
    - IMPL_UTEST_TEST
    - IMPL_UTEST_TYPED_ANY_BEGIN
    - IMPL_UTEST_TYPED_ANY_END
    - TYPED_UTEST*
    - INSTANTIATE_UTEST*
    - UTEST*
    - UPROTO*
    - LOG*
    - RET*
    - UASSERT*
    - UEXPECT*
    - UINVARIANT*
    - USERVER*
    - UTILS*
  BareIdentifierMacros:
    - CALLBACK
    - WINAPI
    - USERVER_IMPL_NODEBUG
    - USERVER_IMPL_NODEBUG_INLINE_FUNC
    - USERVER_IMPL_FORCE_INLINE
    - USERVER_IMPL_DISABLE_ASAN
    - USERVER_IMPL_ALWAYS_INLINE_SIMD
    - USERVER_IMPL_PROTECT_DWCAS_ATTR
    - ATTRIBUTE*
    - FORMAT_USERVER*
    - USERVER_NAMESPACE_BEGIN
    - USERVER_NAMESPACE_END
    - CURL_FORMAT_USERVER_NAMESPACE
    - CURL_8_13_NAMESPACE
    - CURL_SSLVERSION_NAMESPACE
    - UEXPECT_THROW
    - UEXPECT_THROW_MSG
    - UASSERT_THROW
    - UASSERT_THROW_MSG
    - UEXPECT_NO_THROW
    - UASSERT_NO_THROW
  CallSyntaxMacros:
    - UTEST_F_DEATH
    - TYPED_UTEST
    - TYPED_UTEST_P_MT
    - TYPED_UTEST_MT
    - TYPED_UTEST_P
    - UTEST_F_MT
    - UTEST_P_MT
    - UTEST_MT
    - UTEST_DEATH
    - UTEST_F
    - UTEST_P
    - UTEST
    - BENCHMARK_F
    - INSTANTIATE*
    - RET_NAME
    - REGISTER_TYPED*
    - TYPED*
    - USERVER_DEFINE_STRUCT_SUBSET*
StreamShift:
  ConfigurationMethods:
    - std::boolalpha
    - std::noboolalpha
    - std::showbase
    - std::noshowbase
    - std::showpoint
    - std::noshowpoint
    - std::showpos
    - std::noshowpos
    - std::skipws
    - std::noskipws
    - std::uppercase
    - std::nouppercase
    - std::unitbuf
    - std::nounitbuf
    - std::internal
    - std::left
    - std::right
    - std::dec
    - std::hex
    - std::oct
    - std::fixed
    - std::scientific
    - std::hexfloat
    - std::defaultfloat
    - std::setbase
    - std::setfill
    - std::setprecision
    - std::setw
    - std::resetiosflags
    - std::setiosflags
    - std::emit_on_flush
    - std::noemit_on_flush
