# Userver golden-fixture style.
# Keep non-macro style fields in sync with the adjacent userver checkout.
# MacroCategories below are the fixture-specific runtime scanner inputs.
# No IncludeCategories entry: mirrors userver .clang-format IncludeBlocks: Preserve behavior.
---
ColumnLimit: 120
IndentWidth: 4
TabWidth: 4

MainIncludeChar: Quote
IncludeIsMainRegex: '(Test)?$'

MacroCategories:
  RawMacroFunctionDefinitions:
    - LOG_FORMAT_USERVER_LIMITED
  BareIdentifierMacros:
    - USERVER_IMPL_NODEBUG
    - USERVER_IMPL_FORCE_INLINE
    - ATTRIBUTE_NO_SANITIZE_UNDEFINED
    - FORMAT_USERVER_ALWAYS_INLINE_SIMD
    - FORMAT_USERVER_NODEBUG_FUNC
    - FORMAT_USERVER_PROTECTED_ATTR
    - CURL_FORMAT_USERVER_NAMESPACE
    - UEXPECT_THROW
    - UEXPECT_NO_THROW
    - EXPECT_THROW
    - ASSERT_THROW
  CallSyntaxMacros:
    - UTEST_MT
    - UTEST_DEATH
    - BENCHMARK_CAPTURE
    - BENCHMARK_DEFINE_F
    - BENCHMARK_DEFINE_TEMPLATE_F
    - BENCHMARK_INSTANTIATE_TEMPLATE_F
    - BENCHMARK_TEMPLATE
    - MOCK_METHOD
    - INSTANTIATE_UTEST_SUITE_P
    - TYPED_UTEST_MT
    - TYPED_UTEST_P_MT
    - TYPED_UTEST_SUITE_P

StreamShift:
  ConfigurationMethods:
    - std::boolalpha
    - std::noboolalpha
    - std::showbase
    - std::noshowbase
    - std::showpoint
    - std::noshowpoint
    - std::showpos
    - std::noshowpos
    - std::skipws
    - std::noskipws
    - std::uppercase
    - std::nouppercase
    - std::unitbuf
    - std::nounitbuf
    - std::internal
    - std::left
    - std::right
    - std::dec
    - std::hex
    - std::oct
    - std::fixed
    - std::scientific
    - std::hexfloat
    - std::defaultfloat
    - std::setbase
    - std::setfill
    - std::setprecision
    - std::setw
    - std::resetiosflags
    - std::setiosflags
    - std::emit_on_flush
    - std::noemit_on_flush
